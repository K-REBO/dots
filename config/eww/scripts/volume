#!/usr/bin/env bash
# Volume control script using wpctl (PipeWire)

get_volume() {
  wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{print int($2 * 100)}'
}

is_muted() {
  wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | grep -q MUTED
}

get_icon() {
  if is_muted; then
    echo "󰖁"
  else
    vol=$(get_volume)
    if [ "$vol" -ge 70 ]; then
      echo "󰕾"
    elif [ "$vol" -ge 30 ]; then
      echo "󰖀"
    elif [ "$vol" -gt 0 ]; then
      echo "󰕿"
    else
      echo "󰖁"
    fi
  fi
}

update_eww() {
  eww update volume-percent="$(get_volume)" volume-icon="$(get_icon)"
}

listen() {
  # Output initial values
  update_eww

  # Poll every 0.5 seconds for responsive updates
  # PipeWire monitoring is too verbose and inefficient
  while true; do
    sleep 0.5
    update_eww
  done
}

case "$1" in
  icon)
    get_icon
    ;;
  percent)
    get_volume
    ;;
  toggle)
    wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
    update_eww
    ;;
  up)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
    update_eww
    ;;
  down)
    wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    update_eww
    ;;
  set)
    # Set volume to specific percentage (from slider)
    vol="${2%.*}"  # Remove decimal part
    wpctl set-volume @DEFAULT_AUDIO_SINK@ "${vol}%"
    update_eww
    ;;
  listen)
    listen
    ;;
  *)
    # Scroll handling
    if [ "$1" = "up" ] || [ "$1" = "" ]; then
      wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
    else
      wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
    fi
    update_eww
    ;;
esac
