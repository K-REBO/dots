#!/usr/bin/env bash
# Hyprland workspace script with app icons
# Output format: 1[󰈹] 2[󰓇] 3 [S]
# Only shows active workspace and workspaces with windows

# App class to icon mapping
get_icon() {
  case "$1" in
    firefox|Firefox*) echo "󰈹" ;;
    Alacritty|alacritty) echo "󰆍" ;;
    spotify|Spotify) echo "󰓇" ;;
    code|Code|VSCodium) echo "󰨞" ;;
    discord|Discord) echo "󰙯" ;;
    slack|Slack) echo "󰒱" ;;
    telegram*|Telegram*) echo "󰔁" ;;
    chromium*|Chromium*|google-chrome*) echo "󰊯" ;;
    thunar|nautilus|dolphin|pcmanfm) echo "󰉋" ;;
    *) echo "󰀏" ;;
  esac
}

# Track special workspace visibility
SPECIAL_VISIBLE=false

# Get workspaces info from Hyprland
get_workspaces() {
  # Get active workspace
  active=$(hyprctl activeworkspace -j | jq -r '.id')

  # Get clients per workspace
  clients=$(hyprctl clients -j)

  # Build workspace buttons
  result='(box :class "workspaces" :space-evenly false :spacing 4'

  for i in {1..10}; do
    # Check if workspace has windows
    ws_clients=$(echo "$clients" | jq -r ".[] | select(.workspace.id == $i) | .class")

    # Only show active workspace or workspaces with windows
    if [ "$i" = "$active" ] || [ -n "$ws_clients" ]; then
      # Determine class and content
      if [ "$i" = "$active" ]; then
        class="ws ws-$i ws-active"
      else
        class="ws ws-$i ws-occupied"
      fi

      # Build icons for all clients
      if [ -n "$ws_clients" ]; then
        icons=""
        while IFS= read -r client; do
          [ -n "$icons" ] && icons+=" "
          icons+=$(get_icon "$client")
        done <<< "$ws_clients"
        content="${i}[${icons} ]"
      else
        content="$i"
      fi

      result+=" (button :class \"$class\" :onclick \"hyprctl dispatch workspace $i\" \"$content\")"
    fi
  done

  # Special workspace (scratchpad) indicator
  special_clients=$(echo "$clients" | jq -r '.[] | select(.workspace.name | startswith("special")) | .class')
  if [ -n "$special_clients" ]; then
    if [ "$SPECIAL_VISIBLE" = "true" ]; then
      special_class="ws ws-special ws-special-active"
    else
      special_class="ws ws-special ws-special-occupied"
    fi
    special_icons=""
    while IFS= read -r client; do
      [ -n "$special_icons" ] && special_icons+=" "
      special_icons+=$(get_icon "$client")
    done <<< "$special_clients"
    result+=" (button :class \"$special_class\" :onclick \"hyprctl dispatch togglespecialworkspace\" \"[${special_icons} ]\")"
  fi

  result+=")"
  echo "$result"
}

# Initial output
get_workspaces

# Listen for workspace changes
socat -U - UNIX-CONNECT:"$XDG_RUNTIME_DIR/hypr/$HYPRLAND_INSTANCE_SIGNATURE/.socket2.sock" 2>/dev/null | while read -r line; do
  case "$line" in
    togglespecialworkspace*)
      if [ "$SPECIAL_VISIBLE" = "true" ]; then
        SPECIAL_VISIBLE=false
      else
        SPECIAL_VISIBLE=true
      fi
      get_workspaces
      ;;
    workspace*)
      # Switching workspaces hides special workspace
      SPECIAL_VISIBLE=false
      get_workspaces
      ;;
    activewindow*|openwindow*|closewindow*|movewindow*)
      get_workspaces
      ;;
  esac
done
