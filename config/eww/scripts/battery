#!/usr/bin/env bash
# Battery status script

BAT_PATH="/sys/class/power_supply/BAT0"

# Fallback to BAT1 if BAT0 doesn't exist
if [ ! -d "$BAT_PATH" ]; then
  BAT_PATH="/sys/class/power_supply/BAT1"
fi

# If still no battery, show AC icon
if [ ! -d "$BAT_PATH" ]; then
  case "$1" in
    icon) echo "¾░Üź" ;;
    percent) echo "100" ;;
    status) echo "" ;;
  esac
  exit
fi

get_percent() {
  cat "$BAT_PATH/capacity" 2>/dev/null || echo "0"
}

get_status() {
  status=$(cat "$BAT_PATH/status" 2>/dev/null)
  case "$status" in
    Charging) echo "charging" ;;
    Discharging)
      percent=$(get_percent)
      if [ "$percent" -le 20 ]; then
        echo "low"
      else
        echo ""
      fi
      ;;
    *) echo "" ;;
  esac
}

get_icon() {
  status=$(cat "$BAT_PATH/status" 2>/dev/null)
  percent=$(get_percent)

  if [ "$status" = "Charging" ]; then
    echo "¾░éä"
    exit
  fi

  if [ "$percent" -ge 90 ]; then
    echo "¾░ü╣"
  elif [ "$percent" -ge 80 ]; then
    echo "¾░éé"
  elif [ "$percent" -ge 70 ]; then
    echo "¾░éü"
  elif [ "$percent" -ge 60 ]; then
    echo "¾░éĆ"
  elif [ "$percent" -ge 50 ]; then
    echo "¾░ü┐"
  elif [ "$percent" -ge 40 ]; then
    echo "¾░üŠ"
  elif [ "$percent" -ge 30 ]; then
    echo "¾░üĮ"
  elif [ "$percent" -ge 20 ]; then
    echo "¾░ü╝"
  elif [ "$percent" -ge 10 ]; then
    echo "¾░ü╗"
  else
    echo "¾░éÄ"
  fi
}

get_time() {
  status=$(cat "$BAT_PATH/status" 2>/dev/null)

  # Try to get time from power_now and energy_now
  if [ -f "$BAT_PATH/power_now" ] && [ -f "$BAT_PATH/energy_now" ]; then
    power=$(cat "$BAT_PATH/power_now" 2>/dev/null)
    energy=$(cat "$BAT_PATH/energy_now" 2>/dev/null)

    if [ -n "$power" ] && [ "$power" -gt 0 ] && [ -n "$energy" ]; then
      if [ "$status" = "Charging" ]; then
        energy_full=$(cat "$BAT_PATH/energy_full" 2>/dev/null)
        remaining=$((energy_full - energy))
        hours=$((remaining / power))
        minutes=$(( (remaining % power) * 60 / power ))
      else
        hours=$((energy / power))
        minutes=$(( (energy % power) * 60 / power ))
      fi
      printf "%dh %dm\n" "$hours" "$minutes"
      exit
    fi
  fi

  # Fallback: try using current_now
  if [ -f "$BAT_PATH/current_now" ] && [ -f "$BAT_PATH/charge_now" ]; then
    current=$(cat "$BAT_PATH/current_now" 2>/dev/null)
    charge=$(cat "$BAT_PATH/charge_now" 2>/dev/null)

    if [ -n "$current" ] && [ "$current" -gt 0 ] && [ -n "$charge" ]; then
      if [ "$status" = "Charging" ]; then
        charge_full=$(cat "$BAT_PATH/charge_full" 2>/dev/null)
        remaining=$((charge_full - charge))
        hours=$((remaining / current))
        minutes=$(( (remaining % current) * 60 / current ))
      else
        hours=$((charge / current))
        minutes=$(( (charge % current) * 60 / current ))
      fi
      printf "%dh %dm\n" "$hours" "$minutes"
      exit
    fi
  fi

  # Fallback if no time info available
  if [ "$status" = "Charging" ]; then
    echo "Charging"
  elif [ "$status" = "Full" ]; then
    echo "Full"
  else
    echo ""
  fi
}

update_eww() {
  eww update battery-icon="$(get_icon)" \
              battery-percent="$(get_percent)" \
              battery-status="$(get_status)" \
              battery-time="$(get_time)"
}

listen() {
  # Output initial values
  update_eww

  # Monitor battery file changes using inotifywait
  if command -v inotifywait &>/dev/null && [ -d "$BAT_PATH" ]; then
    inotifywait -m -e modify "$BAT_PATH/capacity" "$BAT_PATH/status" 2>/dev/null | while read -r; do
      update_eww
    done
  else
    # Fallback: poll every 30 seconds
    while true; do
      sleep 30
      update_eww
    done
  fi
}

case "$1" in
  icon)
    get_icon
    ;;
  percent)
    get_percent
    ;;
  status)
    get_status
    ;;
  time)
    get_time
    ;;
  listen)
    listen
    ;;
  *)
    get_icon
    ;;
esac
