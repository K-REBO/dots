#!/usr/bin/env bash
# IME (fcitx5) status script

get_icon() {
  # fcitx5-remote returns:
  # 1 = inactive (English)
  # 2 = active (Japanese/other)
  status=$(fcitx5-remote 2>/dev/null)

  case "$status" in
    2)
      echo "あ"
      ;;
    *)
      echo "A"
      ;;
  esac
}

toggle() {
  fcitx5-remote -t 2>/dev/null
}

menu() {
  options="設定\n再起動\nKill"
  selected=$(echo -e "$options" | wofi --dmenu --prompt "IME" --width 150 --height 150)

  case "$selected" in
    "設定")
      fcitx5-configtool &
      ;;
    "再起動")
      fcitx5-remote -e
      sleep 0.5
      fcitx5 -d --replace &
      ;;
    "Kill")
      fcitx5-remote -e
      ;;
  esac
}

update_eww() {
  eww update ime-icon="$(get_icon)"
}

listen() {
  # Output initial value
  update_eww

  # Monitor fcitx5 D-Bus signals for state changes
  if command -v dbus-monitor &>/dev/null; then
    dbus-monitor "type='signal',interface='org.fcitx.Fcitx.InputContext1'" 2>/dev/null | \
      grep --line-buffered -E 'signal|member' | while read -r; do
        update_eww
      done
  else
    # Fallback: poll every 2 seconds
    while true; do
      sleep 2
      update_eww
    done
  fi
}

case "$1" in
  icon)
    get_icon
    ;;
  toggle)
    toggle
    ;;
  menu)
    menu
    ;;
  listen)
    listen
    ;;
  *)
    get_icon
    ;;
esac
