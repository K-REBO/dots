#!/usr/bin/env bash
# Bluetooth status script using bluetoothctl

get_icon() {
  # Check if bluetooth is powered on
  powered=$(bluetoothctl show 2>/dev/null | grep "Powered:" | awk '{print $2}')

  if [ "$powered" != "yes" ]; then
    echo "󰂲"
    exit
  fi

  # Check if any device is connected
  connected=$(bluetoothctl devices Connected 2>/dev/null)

  if [ -n "$connected" ]; then
    echo "󰂱"
  else
    echo "󰂯"
  fi
}

get_status() {
  powered=$(bluetoothctl show 2>/dev/null | grep "Powered:" | awk '{print $2}')

  if [ "$powered" != "yes" ]; then
    echo "Bluetooth Off"
    exit
  fi

  connected=$(bluetoothctl devices Connected 2>/dev/null | head -1 | cut -d' ' -f3-)

  if [ -n "$connected" ]; then
    echo "Connected: $connected"
  else
    echo "Bluetooth On"
  fi
}

get_device() {
  powered=$(bluetoothctl show 2>/dev/null | grep "Powered:" | awk '{print $2}')

  if [ "$powered" != "yes" ]; then
    echo ""
    exit
  fi

  connected=$(bluetoothctl devices Connected 2>/dev/null | head -1 | cut -d' ' -f3-)

  if [ -n "$connected" ]; then
    echo "$connected"
  else
    echo ""
  fi
}

toggle() {
  powered=$(bluetoothctl show 2>/dev/null | grep "Powered:" | awk '{print $2}')

  if [ "$powered" = "yes" ]; then
    bluetoothctl power off
  else
    bluetoothctl power on
  fi
}

update_eww() {
  eww update bluetooth-icon="$(get_icon)" bluetooth-device="$(get_device)"
}

listen() {
  # Output initial values
  update_eww

  # Monitor bluetoothctl events
  if command -v bluetoothctl &>/dev/null; then
    # Use grep to filter relevant events
    bluetoothctl monitor 2>/dev/null | grep --line-buffered -E 'Connected|Disconnected|Device|Controller' | while read -r; do
      update_eww
    done
  else
    # Fallback: poll every 5 seconds
    while true; do
      sleep 5
      update_eww
    done
  fi
}

case "$1" in
  icon)
    get_icon
    ;;
  status)
    get_status
    ;;
  device)
    get_device
    ;;
  toggle)
    toggle
    ;;
  listen)
    listen
    ;;
  *)
    get_icon
    ;;
esac
