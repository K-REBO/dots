#!/usr/bin/env bash
# WiFi status script using nmcli

get_icon() {
  # Check if WiFi is enabled
  wifi_state=$(nmcli radio wifi 2>/dev/null)
  if [ "$wifi_state" = "disabled" ]; then
    echo "󰤭"
    exit
  fi

  # Check connection status
  connection=$(nmcli -t -f TYPE,STATE connection show --active 2>/dev/null | grep "^wifi")
  if [ -z "$connection" ]; then
    echo "󰤯"
    exit
  fi

  # Get signal strength
  signal=$(nmcli -t -f IN-USE,SIGNAL dev wifi list 2>/dev/null | grep "^\*" | cut -d: -f2)

  if [ -z "$signal" ]; then
    echo "󰤨"
  elif [ "$signal" -ge 80 ]; then
    echo "󰤨"
  elif [ "$signal" -ge 60 ]; then
    echo "󰤥"
  elif [ "$signal" -ge 40 ]; then
    echo "󰤢"
  elif [ "$signal" -ge 20 ]; then
    echo "󰤟"
  else
    echo "󰤯"
  fi
}

get_name() {
  ssid=$(nmcli -t -f NAME,TYPE connection show --active 2>/dev/null | grep -E "wireless|wifi" | cut -d: -f1)
  if [ -n "$ssid" ]; then
    echo "Connected: $ssid"
  else
    echo "Disconnected"
  fi
}

get_ssid() {
  ssid=$(nmcli -t -f NAME,TYPE connection show --active 2>/dev/null | grep -E "wireless|wifi" | cut -d: -f1)
  if [ -n "$ssid" ]; then
    echo "$ssid"
  else
    echo ""
  fi
}

get_signal() {
  signal=$(nmcli -t -f IN-USE,SIGNAL dev wifi list 2>/dev/null | grep "^\*" | cut -d: -f2)
  if [ -n "$signal" ]; then
    echo "$signal"
  else
    echo "0"
  fi
}

get_ip() {
  # Get IP address of wifi interface
  wifi_iface=$(nmcli -t -f DEVICE,TYPE device status 2>/dev/null | grep ":wifi$" | cut -d: -f1)
  if [ -n "$wifi_iface" ]; then
    ip=$(ip -4 addr show "$wifi_iface" 2>/dev/null | grep -oP '(?<=inet\s)\d+(\.\d+){3}')
    if [ -n "$ip" ]; then
      echo "$ip"
    else
      echo "N/A"
    fi
  else
    echo "N/A"
  fi
}

get_gateway() {
  # Get default gateway
  gateway=$(ip route show default 2>/dev/null | grep -oP '(?<=via\s)\d+(\.\d+){3}' | head -1)
  if [ -n "$gateway" ]; then
    echo "$gateway"
  else
    echo "N/A"
  fi
}

update_eww() {
  eww update wifi-icon="$(get_icon)" \
              wifi-ssid="$(get_ssid)" \
              wifi-signal="$(get_signal)" \
              wifi-ip="$(get_ip)" \
              wifi-gateway="$(get_gateway)"
}

listen() {
  # Output initial values
  update_eww

  # Monitor NetworkManager events
  if command -v nmcli &>/dev/null; then
    nmcli monitor 2>/dev/null | while read -r; do
      update_eww
    done
  else
    # Fallback: poll every 5 seconds
    while true; do
      sleep 5
      update_eww
    done
  fi
}

case "$1" in
  icon)
    get_icon
    ;;
  name)
    get_name
    ;;
  ssid)
    get_ssid
    ;;
  signal)
    get_signal
    ;;
  ip)
    get_ip
    ;;
  gateway)
    get_gateway
    ;;
  listen)
    listen
    ;;
  *)
    get_icon
    ;;
esac
