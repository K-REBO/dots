;; eww configuration for Hyprland
;; Top horizontal bar with Tokyo Night theme

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;                         State Variables                               ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defvar power-reveal false)
(defvar volume-reveal false)
(defvar brightness-reveal false)
(defvar wifi-reveal false)
(defvar battery-reveal false)

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;                            Widgets                                    ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Power Menu ;;
(defwidget power []
  (eventbox :onhover "${EWW_CMD} update power-reveal=true"
            :onhoverlost "${EWW_CMD} update power-reveal=false"
    (box :class "power-menu" :space-evenly false :spacing 8
      (label :class "power-nixos" :text "󱄅")
      (revealer :transition "slideright" :reveal power-reveal :duration "300ms"
        (box :space-evenly false :spacing 6
          (label :class "power-separator" :text "|")
          (button :class "power-shutdown" :onclick "systemctl poweroff" :tooltip "Shutdown"
            (box :space-evenly false :spacing 4 (label :text "") (label :text "Shutdown")))
          (button :class "power-reboot" :onclick "systemctl reboot" :tooltip "Reboot"
            (box :space-evenly false :spacing 4 (label :text "") (label :text "Reboot")))
          (button :class "power-suspend" :onclick "systemctl suspend" :tooltip "Suspend"
            (box :space-evenly false :spacing 4 (label :text "󰒲") (label :text "Sleep")))
          (button :class "power-lock" :onclick "hyprlock" :tooltip "Lock"
            (box :space-evenly false :spacing 4 (label :text "") (label :text "Lock")))
          (button :class "power-logout" :onclick "hyprctl dispatch exit" :tooltip "Logout"
            (box :space-evenly false :spacing 4 (label :text "󰍃") (label :text "Logout"))))))))

;; Workspaces (Hyprland) ;;
(defwidget workspaces []
  (literal :content workspace))
(deflisten workspace :initial "(box :class 'workspaces' '')" "$HOME/.config/eww/scripts/workspace")

;; Volume ;;
(defwidget volume []
  (eventbox :onhover "${EWW_CMD} update volume-reveal=true"
            :onhoverlost "${EWW_CMD} update volume-reveal=false"
            :onscroll "$HOME/.config/eww/scripts/volume {}"
    (box :class "volume" :space-evenly false :spacing 4
      (revealer :transition "slideright" :reveal volume-reveal :duration "300ms"
        (scale :class "volume-slider"
               :value volume-percent
               :min 0 :max 100
               :onchange "$HOME/.config/eww/scripts/volume set {}"))
      (button :onclick "$HOME/.config/eww/scripts/volume toggle"
        (label :text volume-icon))
      (label :text "${volume-percent}%"))))
(defpoll volume-icon :interval "999999s" "$HOME/.config/eww/scripts/volume icon")
(defpoll volume-percent :interval "999999s" "$HOME/.config/eww/scripts/volume percent")

;; WiFi ;;
(defwidget wifi []
  (eventbox :onhover "${EWW_CMD} update wifi-reveal=true"
            :onhoverlost "${EWW_CMD} update wifi-reveal=false"
    (box :class "wifi" :space-evenly false :spacing 4
      (label :text wifi-icon)
      (label :text wifi-ssid)
      (revealer :transition "slideright" :reveal wifi-reveal :duration "300ms"
        (box :class "wifi-details" :space-evenly false :spacing 8
          (label :text "󰒢 ${wifi-signal}%")
          (label :text " ${wifi-ip}")
          (label :text "󰛳 ${wifi-gateway}")
          (button :class "wifi-settings" :onclick "nm-connection-editor &" :tooltip "Network Settings" "󰒓"))))))
(defpoll wifi-icon :interval "999999s" "$HOME/.config/eww/scripts/wifi icon")
(defpoll wifi-ssid :interval "999999s" "$HOME/.config/eww/scripts/wifi ssid")
(defpoll wifi-signal :interval "999999s" "$HOME/.config/eww/scripts/wifi signal")
(defpoll wifi-ip :interval "999999s" "$HOME/.config/eww/scripts/wifi ip")
(defpoll wifi-gateway :interval "999999s" "$HOME/.config/eww/scripts/wifi gateway")

;; Bluetooth ;;
(defwidget bluetooth []
  (button :class "bluetooth"
          :onclick "$HOME/.config/eww/scripts/bluetooth toggle"
  (box :space-evenly false
       :spacing 4
    (label :text bluetooth-icon)
    (label :text bluetooth-device))))
(defpoll bluetooth-icon :interval "999999s" "$HOME/.config/eww/scripts/bluetooth icon")
(defpoll bluetooth-device :interval "999999s" "$HOME/.config/eww/scripts/bluetooth device")

;; Battery ;;
(defwidget battery []
  (box :class "battery ${battery-status}" :space-evenly false :spacing 4
    (label :text battery-icon)
    (label :text "${battery-percent}%")
    (label :class "battery-time" :text "(${battery-time})")))
(defpoll battery-icon :interval "999999s" "$HOME/.config/eww/scripts/battery icon")
(defpoll battery-percent :interval "999999s" "$HOME/.config/eww/scripts/battery percent")
(defpoll battery-status :interval "999999s" "$HOME/.config/eww/scripts/battery status")
(defpoll battery-time :interval "999999s" "$HOME/.config/eww/scripts/battery time")

;; IME (fcitx5) ;;
(defwidget ime []
  (button :class "ime"
          :onclick "$HOME/.config/eww/scripts/ime toggle"
          :onrightclick "$HOME/.config/eww/scripts/ime menu"
          :tooltip "Input Method"
    ime-icon))
(defpoll ime-icon :interval "999999s" "$HOME/.config/eww/scripts/ime icon")

;; Brightness ;;
(defwidget brightness []
  (eventbox :onhover "${EWW_CMD} update brightness-reveal=true"
            :onhoverlost "${EWW_CMD} update brightness-reveal=false"
            :onscroll "$HOME/.config/eww/scripts/brightness {}"
    (box :class "brightness" :space-evenly false :spacing 4
      (revealer :transition "slideright" :reveal brightness-reveal :duration "300ms"
        (scale :class "brightness-slider"
               :value brightness-percent
               :min 0 :max 100
               :onchange "$HOME/.config/eww/scripts/brightness set {}"))
      (label :text "󰃠")
      (label :text "${brightness-percent}%"))))
(defpoll brightness-percent :interval "1s" "$HOME/.config/eww/scripts/brightness percent")
(deflisten brightness-listener :initial "" "$HOME/.config/eww/scripts/brightness listen")

;; Screen Recorder ;;
(defwidget recorder []
  (box :class "recorder ${recorder-status != '' ? 'recording' : ''}"
       :visible {recorder-status != ''}
       :space-evenly false
       :spacing 4
    (label :class "recorder-icon" :text "")
    (label :class "recorder-text" :text recorder-status)))
(deflisten recorder-status :initial "" "$HOME/.config/eww/scripts/recorder")

;; Taildrop ;;
(defwidget taildrop []
  (box :class "taildrop ${taildrop-data.status == '受信中' ? 'taildrop-receiving' : ''}"
       :visible {taildrop-data.active}
       :space-evenly false
       :spacing 8
    (label :class "taildrop-icon" :text "󰛶")
    (box :orientation "v" :space-evenly false :spacing 2
      (label :class "taildrop-filename"
             :text {taildrop-data.filename}
             :limit-width 18
             :truncate true)
      (label :class "taildrop-status"
             :text {taildrop-data.size != "" ? "${taildrop-data.status} ${taildrop-data.size}" : taildrop-data.status}))))
(deflisten taildrop-data
  :initial '{"active":false,"filename":"","status":"","size":""}'
  "$HOME/.config/eww/scripts/taildrop")

;; DateTime ;;
(defwidget datetime []
  (eventbox :class "datetime"
            :onhover "${EWW_CMD} open calendar"
    (box :space-evenly false :spacing 8
      (label :text "")
      (label :class "date" :text date-text)
      (label :class "time" :text time-text)
      (label :text ""))))
(defpoll date-text :interval "60s" "LC_TIME=C date '+%m/%d %a'")
(defpoll time-text :interval "1s" "date '+%H:%M'")
(defpoll calendar-day :interval "60s" "date '+%d'")
(defpoll calendar-month :interval "3600s" "date '+%m'")
(defpoll calendar-year :interval "3600s" "date '+%Y'")

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;                          Bar Layout                                   ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

;; Left Section ;;
(defwidget left []
  (box :class "left"
       :space-evenly false
       :halign "start"
       :spacing 12
    (power)
    (workspaces)))

;; Center Section (empty) ;;
(defwidget center []
  (box :class "center"
       :halign "center"))

;; Right Section ;;
(defwidget right []
  (box :class "right"
       :space-evenly false
       :halign "end"
       :spacing 12
    (taildrop)
    (volume)
    (wifi)
    (bluetooth)
    (battery)
    (ime)
    (brightness)
    (recorder)
    (datetime)))

;; Main Bar ;;
(defwidget bar []
  (centerbox :class "bar"
             :orientation "h"
    (left)
    (center)
    (right)))

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;                         Calendar Popup                                ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defwidget calendar-popup []
  (box :class "calendar-popup" :orientation "v" :space-evenly false :spacing 12
    ;; Current time display
    (box :class "calendar-time-section" :orientation "v" :space-evenly false :halign "center"
      (label :class "calendar-time" :text time-text)
      (label :class "calendar-date-full" :text date-full))
    ;; Calendar
    (box :class "calendar-section" :halign "center"
      (calendar :class "calendar"
                :day calendar-day
                :month calendar-month
                :year calendar-year))))

(defpoll date-full :interval "60s" "LC_TIME=C date '+%A, %B %d, %Y'")

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;                            Windows                                    ;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defwindow calendar
  :monitor 0
  :geometry (geometry :x "0"
                      :y "0"
                      :width "100%"
                      :height "100%"
                      :anchor "top center")
  :stacking "overlay"
  :exclusive false
  :focusable false
  (eventbox :onclick "${EWW_CMD} close calendar"
    (box :class "calendar-overlay" :halign "end" :valign "start"
      (eventbox :onclick "echo"
                :onhoverlost "${EWW_CMD} close calendar"
        (calendar-popup)))))

(defwindow bar
  :monitor 0
  :geometry (geometry :x "0"
                      :y "0"
                      :width "100%"
                      :height "40px"
                      :anchor "top center")
  :stacking "fg"
  :exclusive true
  :focusable false
  (bar))
